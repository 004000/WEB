# Backend
SERVER_PORT=3000
SECRET_KEY=supersecretkey
REDIS_ADDR=/app/data/kvrocks.sock
REDIS_PROTOCOL=unix
# Set to 1 to connect over TLS (needed for cloud Redis providers like Upstash).
# Leave unset/0 for local unix-socket kvrocks via docker-compose.
REDIS_TLS=0
# Automatic cleanup + backup of old messages (optional):
# CLEANUP_RETENTION_DAYS=90
# STORAGE_EMERGENCY_THRESHOLD_PERCENT=80   (purge oldest messages regardless of age once usage crosses this %, checked hourly)
# GITHUB_BACKUP_TOKEN=github_pat_...   (fine-grained PAT with Contents: Read and write on the backup repo)
# GITHUB_BACKUP_REPO=owner/repo        (repo where JSON backups are committed before permanent deletion)

# Google-oauth2
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
ADMIN_USERS=example@gmail.com,example1@gmail.com